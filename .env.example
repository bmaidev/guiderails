# Credentials for exploratory real-agent runs (04-assurance/harness).
#
#   cp .env.example .env      then fill in the keys you hold
#
# .env is gitignored and must stay that way. No secrets in the repo, ever
# (CLAUDE.md, engineering standards). This file carries names, never values.
#
# Nothing else in the repository needs credentials: the fixture makes no
# external network calls at runtime, and the test suites run offline.
#
# Only the vendor you are running needs its key set. The harness checks before
# it makes a request, and names the variable it wanted.

# Anthropic — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google (Gemini) — https://aistudio.google.com/apikey
# The SDK also accepts GEMINI_API_KEY; set either.
GOOGLE_API_KEY=
